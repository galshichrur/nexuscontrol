API_HOST=127.0.0.1  # Use 0.0.0.0 for remote server

# TCP Server
SERVER_HOST=  # Enter server IP address
SERVER_PORT=8080

# Data
DB_PATH=data/nexuscontrol.db
LOGS_PATH=data/logs

# Frontend build path
FRONTEND_BUILD_PATH=../frontend/out

# API
API_PREFIX=/api
API_TITLE=Nexus Control API
API_VERSION=0.1.0
API_PORT=8000

# CORS
ALLOWED_ORIGINS=  # Keep empty

# Server Settings
SERVER_RECV_HEARTBEAT_TIMEOUT=185
CMD_EXECUTE_TIMEOUT=25